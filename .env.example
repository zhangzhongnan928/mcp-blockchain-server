# All settings are OPTIONAL. The server runs with zero configuration.
# Copy this file to `.env` only if you want to override a default.

# --- Signing web server ---
# PORT=3000
# HOST=127.0.0.1
# Set PUBLIC_BASE_URL when the signing page is reachable at a non-localhost URL.
# PUBLIC_BASE_URL=http://localhost:3000

# --- Defaults ---
# Default chain when a tool call omits chainId (11155111 = Sepolia testnet).
# DEFAULT_CHAIN_ID=11155111
# LOG_LEVEL=info            # error | warn | info | debug (logs go to stderr)
# Directory for the pending-transaction store (defaults to ~/.mcp-blockchain).
# MCP_DATA_DIR=

# --- RPC endpoints (optional) ---
# Every chain ships with a free public RPC. Override per-chain if you prefer:
# RPC_URL_1=https://your-eth-node
# RPC_URL_11155111=https://your-sepolia-node
# Or set an Infura key to upgrade the default endpoints:
# INFURA_API_KEY=

# --- Contract ABIs (optional) ---
# Lets `read-contract` auto-fetch verified ABIs (Etherscan v2, multichain).
# Otherwise pass an `abi` argument directly.
# ETHERSCAN_API_KEY=
